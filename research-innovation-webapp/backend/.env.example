# ═══════════════════════════════════════════════════════════
# Research & Innovation SAC — Variables de entorno del backend
# Copia este archivo como ".env" y ajusta los valores.
# NUNCA subas el archivo ".env" real a un repositorio público.
# ═══════════════════════════════════════════════════════════

# Entorno: development | production
NODE_ENV=development

# Puerto donde correrá el servidor Express (sirve API + sitio + admin)
PORT=3000

# ── Base de datos MySQL / MariaDB ──────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ri_patentes
DB_USER=ri_app
DB_PASSWORD=ri_app_pass_2026

# ── Autenticación ───────────────────────────────────────────
# Genera un valor propio y largo con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia_este_valor_por_uno_generado_aleatoriamente
JWT_EXPIRES_IN=8h

# Nombre de la cookie httpOnly donde se guarda el token de sesión
COOKIE_NAME=ri_token

# ── CORS ─────────────────────────────────────────────────────
# Origen permitido si el frontend se sirve desde un dominio/puerto
# distinto al del backend. Déjalo vacío si usas el mismo servidor
# Express para servir todo (configuración por defecto de este proyecto).
CORS_ORIGIN=

# ── Carga de archivos ────────────────────────────────────────
UPLOAD_MAX_MB=20
